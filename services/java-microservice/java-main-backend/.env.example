# ============================================================
# AssetFlow - Environment template (auth + organisation-setup)
# Copy to .env and fill in real values:  cp .env.example .env
# ============================================================

# Server
SERVER_PORT=8080

# ---------- Database: PostgreSQL (Neon) ----------
DATABASE_URL=jdbc:postgresql://<neon-host>/<database>?sslmode=require
DATABASE_USERNAME=<db-username>
DATABASE_PASSWORD=<db-password>

# ---------- Redis: Upstash (TLS) ----------
# From redis://default:<TOKEN>@host:6379 -> username "default", <TOKEN> is the password
REDIS_HOST=<your-instance>.upstash.io
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=<upstash-token>
REDIS_SSL=true

# ---------- JWT (shared by BOTH modules) ----------
# Generate with: openssl rand -base64 64   (minimum 32 characters)
# One secret signs and verifies tokens across auth + organisation-setup.
JWT_SECRET=<random-base64-secret-at-least-32-chars>
JWT_ISSUER=assetflow-auth
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
REFRESH_TOKEN_EXPIRATION_DAYS=7

# ---------- Mail: Mailjet REST API ----------
# Get these from https://app.mailjet.com/account/apikeys
# When present the app sends real emails; leave blank to log links to the console.
# The sender email must be an authenticated Mailjet sender/domain.
mailjet.api-key=<mailjet-api-key>
mailjet.secret-key=<mailjet-secret-key>
mailjet.sender-email=<verified-sender@yourdomain.com>
mailjet.sender-name=Your App Name
app.name=Your App Name

# ---------- Cloudinary: media uploads (asset photos, documents, profiles) ----------
# Get the URL from https://console.cloudinary.com  (Dashboard -> API Environment variable)
# Provide EITHER the single URL (recommended) ...
cloudinary.url=cloudinary://<api-key>:<api-secret>@<cloud-name>
# ... OR the three split values (leave cloudinary.url blank if you use these):
# cloudinary.cloud-name=<cloud-name>
# cloudinary.api-key=<api-key>
# cloudinary.api-secret=<api-secret>

# ---------- Security ----------
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=30
VERIFICATION_TOKEN_TTL_HOURS=24
RESET_TOKEN_TTL_MINUTES=30
RESEND_COOLDOWN_SECONDS=60

# ---------- Frontend / CORS (shared by BOTH modules) ----------
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
